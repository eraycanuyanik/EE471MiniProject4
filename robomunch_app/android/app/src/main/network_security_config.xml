<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow plain http to LAN backend (your laptop) and the cloud VM. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
